{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/LogicWriting/schemas/source-registry.schema.json",
  "title": "Logic Writing SourceRegistry",
  "description": "A current source inventory with observed anchors, citation labels, access, lineage, source role, and exact support boundaries. Candidate-only records cannot carry factual support.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "sources"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "registry_id": { "$ref": "#/$defs/identifier" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}(?:-[0-9]{2}(?:-[0-9]{2})?)?$"
    },
    "sourceRole": {
      "enum": [
        "primary",
        "official",
        "implementation",
        "outcome",
        "method",
        "context",
        "counterevidence",
        "critique",
        "data",
        "secondary"
      ]
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_id", "locator", "observed_summary"],
      "properties": {
        "anchor_id": { "$ref": "#/$defs/identifier" },
        "locator": { "type": "string", "minLength": 1 },
        "observed_summary": { "type": "string", "minLength": 1 }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "locator",
        "citation_label",
        "source_date",
        "coverage_period",
        "role",
        "lineage_id",
        "independence",
        "observation_status",
        "access_status",
        "observed_content_fingerprint",
        "observation_receipt_fingerprint",
        "anchors",
        "can_support",
        "cannot_support"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/identifier" },
        "locator": { "type": "string", "minLength": 1 },
        "citation_label": { "type": "string", "minLength": 1 },
        "source_date": {
          "anyOf": [
            { "$ref": "#/$defs/date" },
            { "type": "null" }
          ]
        },
        "coverage_period": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["start", "end", "description"],
          "properties": {
            "start": {
              "anyOf": [
                { "$ref": "#/$defs/date" },
                { "type": "null" }
              ]
            },
            "end": {
              "anyOf": [
                { "$ref": "#/$defs/date" },
                { "type": "null" }
              ]
            },
            "description": { "type": "string", "minLength": 1 }
          }
        },
        "role": { "$ref": "#/$defs/sourceRole" },
        "lineage_id": { "$ref": "#/$defs/identifier" },
        "independence": {
          "enum": ["independent", "same_lineage", "unknown", "not_applicable"]
        },
        "observation_status": {
          "enum": ["candidate", "observed", "claim_usable", "rejected", "access_gap"]
        },
        "access_status": {
          "enum": ["available", "permission_gated", "unavailable", "not_attempted"]
        },
        "observed_content_fingerprint": {
          "anyOf": [
            { "$ref": "#/$defs/fingerprint" },
            { "type": "null" }
          ]
        },
        "observation_receipt_fingerprint": {
          "anyOf": [
            { "$ref": "#/$defs/fingerprint" },
            { "type": "null" }
          ]
        },
        "anchors": {
          "type": "array",
          "items": { "$ref": "#/$defs/anchor" },
          "uniqueItems": true
        },
        "can_support": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "cannot_support": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["observation_status"],
            "properties": { "observation_status": { "const": "claim_usable" } }
          },
          "then": {
            "properties": {
              "access_status": { "const": "available" },
              "can_support": { "minItems": 1 },
              "observed_content_fingerprint": { "$ref": "#/$defs/fingerprint" },
              "observation_receipt_fingerprint": { "$ref": "#/$defs/fingerprint" },
              "anchors": { "minItems": 1 }
            }
          },
          "else": {
            "properties": { "can_support": { "maxItems": 0 } }
          }
        },
        {
          "if": {
            "required": ["access_status"],
            "properties": {
              "access_status": {
                "enum": ["permission_gated", "unavailable", "not_attempted"]
              }
            }
          },
          "then": {
            "properties": { "can_support": { "maxItems": 0 } }
          }
        }
      ]
    }
  }
}
