{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/LogicWriting/schemas/obligation-manifest.schema.json",
  "title": "Logic Writing FlowGuard-derived closure obligation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "contract_receipt_fingerprint",
    "contract_semantic_owner_id",
    "artifact_fingerprint",
    "route_decision",
    "final_owner",
    "broad_claim_requested",
    "obligations",
    "contract_projection_fingerprint",
    "manifest_fingerprint"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "manifest_id": { "$ref": "#/$defs/identifier" },
    "contract_receipt_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "contract_semantic_owner_id": { "$ref": "#/$defs/identifier" },
    "artifact_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "route_decision": { "$ref": "route-decision.schema.json" },
    "final_owner": { "enum": ["investigation", "academic-writing"] },
    "broad_claim_requested": { "type": "boolean" },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/obligation" }
    },
    "contract_projection_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "manifest_fingerprint": { "$ref": "#/$defs/fingerprint" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "obligation_id",
        "producer_skill",
        "semantic_owner_id",
        "native_route",
        "evidence_domain",
        "required_input_fingerprints",
        "required_output_fingerprints",
        "critical",
        "next_owner",
        "affected_scope",
        "safe_claim",
        "unsafe_claim_boundary",
        "action"
      ],
      "properties": {
        "obligation_id": { "$ref": "#/$defs/identifier" },
        "producer_skill": { "$ref": "#/$defs/identifier" },
        "semantic_owner_id": { "$ref": "#/$defs/identifier" },
        "native_route": { "$ref": "#/$defs/identifier" },
        "evidence_domain": { "$ref": "#/$defs/identifier" },
        "required_input_fingerprints": { "$ref": "#/$defs/fingerprintMap" },
        "required_output_fingerprints": { "$ref": "#/$defs/fingerprintMap" },
        "critical": { "type": "boolean" },
        "next_owner": { "$ref": "#/$defs/identifier" },
        "affected_scope": { "type": "string", "minLength": 1 },
        "safe_claim": { "type": "string", "minLength": 1 },
        "unsafe_claim_boundary": { "type": "string", "minLength": 1 },
        "action": { "$ref": "#/$defs/identifier" }
      }
    },
    "fingerprintMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "$ref": "#/$defs/identifier" },
      "additionalProperties": { "$ref": "#/$defs/fingerprint" }
    }
  }
}
