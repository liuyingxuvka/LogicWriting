{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/LogicWriting/schemas/reader-brief.schema.json",
  "title": "Logic Writing ReaderBrief",
  "description": "A reader-facing plan derived only from a current ResearchPacket and a small reader context. Evidence, findings, limits, order, and citations are not caller-authored.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "brief_id",
    "packet_fingerprint",
    "reader_context_fingerprint",
    "reader_question",
    "audience",
    "genre",
    "purpose",
    "concepts",
    "principal_findings",
    "evidence_anchors",
    "alternatives",
    "limitations",
    "information_sequence",
    "required_citations",
    "allowed_wording",
    "prohibited_wording",
    "brief_fingerprint"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "brief_id": { "$ref": "#/$defs/identifier" },
    "packet_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "reader_context_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "reader_question": { "$ref": "#/$defs/readerText" },
    "audience": { "$ref": "#/$defs/readerText" },
    "genre": { "$ref": "#/$defs/readerText" },
    "purpose": { "$ref": "#/$defs/readerText" },
    "concepts": {
      "type": "array",
      "items": { "$ref": "#/$defs/concept" },
      "uniqueItems": true
    },
    "principal_findings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/finding" },
      "uniqueItems": true
    },
    "evidence_anchors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceAnchor" },
      "uniqueItems": true
    },
    "alternatives": {
      "type": "array",
      "items": { "$ref": "#/$defs/alternative" },
      "uniqueItems": true
    },
    "limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/limitation" },
      "uniqueItems": true
    },
    "information_sequence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sequenceItem" },
      "uniqueItems": true
    },
    "required_citations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/citation" },
      "uniqueItems": true
    },
    "allowed_wording": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/readerText" },
      "uniqueItems": true
    },
    "prohibited_wording": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/readerText" },
      "uniqueItems": true
    },
    "brief_fingerprint": { "$ref": "#/$defs/fingerprint" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "readerText": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*\\b(?:SourceGuard|LogicGuard|TraceGuard|FlowGuard)\\b)(?!.*\\b(?:current_pass|provider_unavailable|render_not_run|closure_status)\\b).+$"
    },
    "sourceRole": {
      "enum": [
        "primary",
        "official",
        "implementation",
        "outcome",
        "method",
        "context",
        "counterevidence",
        "critique",
        "data",
        "secondary"
      ]
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concept_id", "term", "explanation", "introduction_order"],
      "properties": {
        "concept_id": { "$ref": "#/$defs/identifier" },
        "term": { "$ref": "#/$defs/readerText" },
        "explanation": { "$ref": "#/$defs/readerText" },
        "introduction_order": { "type": "integer", "minimum": 1 }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "claim_ids",
        "text",
        "evidence_anchor_ids",
        "limitation_ids"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/identifier" },
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "text": { "$ref": "#/$defs/readerText" },
        "evidence_anchor_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "limitation_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        }
      }
    },
    "evidenceAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "claim_id",
        "source_id",
        "source_anchor_id",
        "relation",
        "locator",
        "observed_summary",
        "source_role",
        "reader_role",
        "supported_wording",
        "boundary"
      ],
      "properties": {
        "anchor_id": { "$ref": "#/$defs/identifier" },
        "claim_id": { "$ref": "#/$defs/identifier" },
        "source_id": { "$ref": "#/$defs/identifier" },
        "source_anchor_id": { "$ref": "#/$defs/identifier" },
        "relation": { "enum": ["support", "limit", "counter", "context"] },
        "locator": { "$ref": "#/$defs/readerText" },
        "observed_summary": { "$ref": "#/$defs/readerText" },
        "source_role": { "$ref": "#/$defs/sourceRole" },
        "reader_role": { "$ref": "#/$defs/readerText" },
        "supported_wording": { "$ref": "#/$defs/readerText" },
        "boundary": { "$ref": "#/$defs/readerText" }
      }
    },
    "alternative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alternative_id",
        "text",
        "treatment",
        "claim_ids",
        "evidence_anchor_ids"
      ],
      "properties": {
        "alternative_id": { "$ref": "#/$defs/identifier" },
        "text": { "$ref": "#/$defs/readerText" },
        "treatment": { "enum": ["live", "qualified", "rejected", "unsupported"] },
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "evidence_anchor_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        }
      }
    },
    "limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "limitation_id",
        "text",
        "affected_finding_ids",
        "evidence_anchor_ids",
        "placement"
      ],
      "properties": {
        "limitation_id": { "$ref": "#/$defs/identifier" },
        "text": { "$ref": "#/$defs/readerText" },
        "affected_finding_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "evidence_anchor_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "placement": { "enum": ["near_claim", "section", "conclusion", "appendix"] }
      }
    },
    "sequenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "item_kind", "item_id", "prior_item_ids", "purpose", "handoff"],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "item_kind": { "enum": ["finding", "alternative", "limitation"] },
        "item_id": { "$ref": "#/$defs/identifier" },
        "prior_item_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "purpose": { "$ref": "#/$defs/readerText" },
        "handoff": { "$ref": "#/$defs/readerText" }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_id",
        "target_kind",
        "target_id",
        "evidence_anchor_ids",
        "source_id",
        "citation_label",
        "locator",
        "marker",
        "supported_wording"
      ],
      "properties": {
        "citation_id": { "$ref": "#/$defs/identifier" },
        "target_kind": { "enum": ["finding", "limitation", "alternative"] },
        "target_id": { "$ref": "#/$defs/identifier" },
        "evidence_anchor_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "source_id": { "$ref": "#/$defs/identifier" },
        "citation_label": { "$ref": "#/$defs/readerText" },
        "locator": { "$ref": "#/$defs/readerText" },
        "marker": { "type": "string", "pattern": "^\\[S[1-9][0-9]*\\]$" },
        "supported_wording": { "$ref": "#/$defs/readerText" }
      }
    }
  }
}
