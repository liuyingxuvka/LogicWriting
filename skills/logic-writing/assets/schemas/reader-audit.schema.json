{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/LogicWriting/schemas/reader-audit.schema.json",
  "title": "Logic Writing actual-artifact deterministic reader audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "artifact_locator",
    "artifact_fingerprint",
    "audited_text_fingerprint",
    "artifact_extraction_receipt_fingerprint",
    "reader_brief_fingerprint",
    "reader_brief_receipt_fingerprint",
    "genre",
    "visible_units",
    "reverse_outline",
    "findings",
    "status",
    "audit_fingerprint"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "audit_id": { "$ref": "#/$defs/identifier" },
    "artifact_locator": { "type": "string", "minLength": 1 },
    "artifact_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "audited_text_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "artifact_extraction_receipt_fingerprint": {
      "anyOf": [
        { "$ref": "#/$defs/fingerprint" },
        { "type": "null" }
      ]
    },
    "reader_brief_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "reader_brief_receipt_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "genre": { "type": "string", "minLength": 1 },
    "visible_units": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/visibleUnit" }
    },
    "reverse_outline": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/outlineRow" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "status": { "enum": ["passed", "partial", "failed", "blocked"] },
    "audit_fingerprint": { "$ref": "#/$defs/fingerprint" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "visibleUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "kind", "locator", "content_fingerprint", "text"],
      "properties": {
        "unit_id": { "$ref": "#/$defs/identifier" },
        "kind": { "enum": ["heading", "paragraph", "list_item", "table_row", "blockquote"] },
        "locator": { "type": "string", "minLength": 1 },
        "content_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "outlineRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "kind", "purpose", "old_information_link", "next_handoff"],
      "properties": {
        "unit_id": { "$ref": "#/$defs/identifier" },
        "kind": { "enum": ["heading", "paragraph", "list_item", "table_row", "blockquote"] },
        "purpose": { "type": "string", "minLength": 1 },
        "old_information_link": { "enum": ["explicit", "implicit"] },
        "next_handoff": { "type": "string", "minLength": 1 }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "locator", "code", "details"],
      "properties": {
        "unit_id": { "type": ["string", "null"] },
        "locator": { "type": ["string", "null"] },
        "code": { "$ref": "#/$defs/identifier" },
        "details": {}
      }
    }
  }
}
