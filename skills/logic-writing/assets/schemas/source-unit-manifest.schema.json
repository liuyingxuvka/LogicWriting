{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/LogicWriting/schemas/source-unit-manifest.schema.json",
  "title": "Logic Writing source-unit manifest",
  "description": "A verifier-derived complete visible-unit universe for exact source and target artifact bytes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "source", "target", "manifest_fingerprint"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "manifest_id": { "$ref": "#/$defs/identifier" },
    "source": { "$ref": "#/$defs/artifact" },
    "target": { "$ref": "#/$defs/artifact" },
    "manifest_fingerprint": { "$ref": "#/$defs/fingerprint" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locator", "artifact_fingerprint", "byte_length", "units"],
      "properties": {
        "locator": { "type": "string", "minLength": 1 },
        "artifact_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "byte_length": { "type": "integer", "minimum": 1 },
        "units": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/unit" }
        }
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_id",
        "kind",
        "locator",
        "line_start",
        "line_end",
        "byte_start",
        "byte_end",
        "content_fingerprint"
      ],
      "properties": {
        "unit_id": { "$ref": "#/$defs/identifier" },
        "kind": { "enum": ["heading", "paragraph", "list_item", "table_row", "blockquote"] },
        "locator": { "type": "string", "pattern": "^line:[1-9][0-9]*(?:-[1-9][0-9]*)?$" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "byte_start": { "type": "integer", "minimum": 0 },
        "byte_end": { "type": "integer", "minimum": 1 },
        "content_fingerprint": { "$ref": "#/$defs/fingerprint" }
      }
    }
  }
}
